# Copy to .env.local and fill only the providers you want to enable.

# Default cloud model: DashScope OpenAI-compatible qwen-max
DASHSCOPE_API_KEY=

# Gateway bind + optional auth (defaults: 127.0.0.1, no auth)
# TOOL_GATEWAY_HOST=127.0.0.1
# TOOL_GATEWAY_PORT=8787
TOOL_GATEWAY_API_KEY=

# SocialHub bridge: real reads only when provider tokens are configured.
# Uses TOOL_GATEWAY_API_KEY above when gateway auth is enabled.
# X/Twitter: any one token works for recent search.
X_BEARER_TOKEN=
# or:
# X_ACCESS_TOKEN=
# X_OAUTH_TOKEN=
# Slack: user token is preferred for search.messages.
SLACK_USER_TOKEN=
# or:
# SLACK_BOT_TOKEN=
# WeCom reads from callback cache.
WECOM_CALLBACK_TOKEN=
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_ENCODING_AES_KEY=

# Flights: VariFlight MCP/API
FLIGHT_MCP_KEY=
# or:
# VARIFLIGHT_API_KEY=
# Optional override:
# VARIFLIGHT_API_URL=https://mcp.variflight.com/api/v1/mcp/data

# Food: aggregate search providers
AMAP_KEY=
AMAP_DEFAULT_LOCATION=116.397428,39.90923
# Optional override:
# AMAP_RADIUS=3000

# Food: Tencent Location Service POI nearby search
TENCENT_MAP_KEY=
# Optional override:
# TENCENT_MAP_API_URL=https://apis.map.qq.com/ws/place/v1/search

# Food: Baidu Map Place API nearby search
BAIDU_MAP_AK=
# Optional override:
# BAIDU_MAP_API_URL=https://api.map.baidu.com/place/v2/search

# Food: Meituan Union product query
MEITUAN_UNION_APP_KEY=
MEITUAN_UNION_APP_SECRET=
# Optional override:
# MEITUAN_UNION_API_URL=https://media.meituan.com/cps_open/common/api/v1/query_coupon

# Food: Taobao Flash / Ele.me union store promotion query
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_FLASH_PID=
# Optional override:
# TAOBAO_API_URL=https://eco.taobao.com/router/rest

# Food: McDonald's China official MCP, query-only in AIPhoneDemo
# Get a token from https://open.mcd.cn/mcp
MCD_MCP_TOKEN=
# Optional override:
# MCD_MCP_URL=https://mcp.mcd.cn

# Food: Luckin Coffee official AI open platform MCP, query-only in AIPhoneDemo
# Get a token from https://open.lkcoffee.com/
LUCKIN_MCP_TOKEN=
# Optional override:
# LUCKIN_MCP_URL=https://gwmcp.lkcoffee.com/order/user/mcp

# Google Calendar and Maps
GOOGLE_MAPS_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=com.example.aiphonedemo:/oauth/google

# Gmail: official Google Workspace Gmail MCP + OAuth
# Server: https://gmailmcp.googleapis.com/mcp/v1
# Enable Gmail API and Gmail MCP API in Google Cloud, then create an OAuth
# client with redirect URI com.example.aiphonedemo:/oauth/google. First use opens Google
# consent; the app stores refresh/access tokens in AssetStore and reuses them.
# Native/public clients may omit the secret. Web clients usually need it for
# the token exchange.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=com.example.aiphonedemo:/oauth/google
GMAIL_MCP_USER_PROJECT=
# Optional override when you host your own OAuth start endpoint:
# GMAIL_AUTH_URL=http://127.0.0.1:8787/oauth/google/start

# YouTube: public search. OAuth-backed account content reuses GOOGLE_OAUTH_* above.
YOUTUBE_API_KEY=

# Optional generic adapters
# TRAIN_API_URL=
# TRAIN_API_KEY=
# Max trains returned per query (6-50, default 30)
# TRAIN_RESULT_LIMIT=30
