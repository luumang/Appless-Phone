# Copy to .env.local and fill only the providers you want to enable.

# Gateway bind + optional auth (defaults: 127.0.0.1, no auth)
# TOOL_GATEWAY_HOST=127.0.0.1
# TOOL_GATEWAY_PORT=8787
# TOOL_GATEWAY_API_KEY=

# Flights: VariFlight MCP/API
FLIGHT_MCP_KEY=
# or:
# VARIFLIGHT_API_KEY=
# Optional override:
# VARIFLIGHT_API_URL=https://mcp.variflight.com/api/v1/mcp/data

# Food: Amap Web Service POI
AMAP_KEY=
AMAP_DEFAULT_LOCATION=116.397428,39.90923

# Optional generic adapters
# TRAIN_API_URL=
# TRAIN_API_KEY=
# Max trains returned per query (6-50, default 30)
# TRAIN_RESULT_LIMIT=30
# FOOD_API_URL=
# FOOD_API_KEY=
