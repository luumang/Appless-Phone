import { A2uiAction, A2uiLabelValueData } from './A2uiTypes';
import { genericToolResultsA2ui } from './DynamicToolA2ui';
import { DynamicGenericToolResult } from './DynamicToolTypes';
import {
  HotelDetailRequest,
  HotelDetailResult,
  HotelRatePlan,
  HotelSearchItem,
  HotelSearchRequest,
  HotelSearchResult
} from './HotelToolTypes';

const HOTEL_SOURCE: string = 'RollingGo';
const HOTEL_LIMITATION: string = 'Appless жҡӮдёҚж”ҜжҢҒеҲӣе»әжҲ–и·ҹиёӘй…’еә—и®ўеҚ•';
const HOTEL_PRICE_LIMITATION: string = 'зЁҺиҙ№жӢҶеҲҶдёҺжҠҘд»·жңүж•Ҳжңҹпјҡдҫӣеә”е•ҶжңӘиҝ”еӣһ';
const HOTEL_SEARCH_PRICE_SCOPE: string = 'жҗңзҙўйҳ¶ж®өд»…дј жҲҗдәәж•°пјӣе®Ңж•ҙе®ўдәәдёҺжҲҝй—ҙж•°еңЁе®һж—¶жҲҝеһӢдёӯжҹҘиҜў';

function row(label: string, value: string): A2uiLabelValueData {
  return {
    label: label,
    value: value
  };
}

function numberText(value: number): string {
  return Number.isFinite(value) ? value.toString() : '';
}

function occupancyText(adults: number, children: number, rooms: number): string {
  let value = adults.toString() + ' жҲҗдәә';
  if (children > 0) {
    value += ' В· ' + children.toString() + ' е„ҝз«Ҙ';
  }
  return value + ' В· ' + rooms.toString() + ' й—ҙ';
}

function ratePriceText(rate: HotelRatePlan): string {
  if (rate.averagePrice === null || rate.currency.length === 0) {
    return 'дҫӣеә”е•ҶжңӘиҝ”еӣһ';
  }
  return numberText(rate.averagePrice) + ' ' + rate.currency;
}

function rateAvailabilityText(rate: HotelRatePlan): string {
  if (rate.isOnRequest === null) {
    return 'дҫӣеә”е•ҶжңӘиҝ”еӣһ';
  }
  return rate.isOnRequest ? 'йңҖдәҢж¬ЎзЎ®и®Ө' : 'еҪ“еүҚеҸҜи®ў';
}

function searchErrorResult(result: HotelSearchResult): DynamicGenericToolResult {
  return {
    sourceTag: HOTEL_SOURCE,
    toolName: 'hotel.search',
    title: 'й…’еә—жҗңзҙўеӨұиҙҘ',
    status: 'error',
    summary: result.error,
    rows: [
      row('е…ҘдҪҸ', result.query.checkInDate + ' вҶ’ ' + result.query.checkOutDate),
      row('е®ўдәә', occupancyText(result.query.adultCount, result.query.childCount, result.query.roomCount)),
      row('иғҪеҠӣиҫ№з•Ң', HOTEL_LIMITATION)
    ],
    rawPreview: ''
  };
}

function detailErrorResult(result: HotelDetailResult): DynamicGenericToolResult {
  return {
    sourceTag: HOTEL_SOURCE,
    toolName: 'hotel.detail',
    title: 'жҲҝеһӢдёҺжҠҘд»·жҹҘиҜўеӨұиҙҘ',
    status: 'error',
    summary: result.error,
    rows: [
      row('й…’еә— ID', result.query.hotelId.toString()),
      row('е…ҘдҪҸ', result.query.checkInDate + ' вҶ’ ' + result.query.checkOutDate),
      row('е®ўдәә', occupancyText(result.query.adultCount, result.query.childCount, result.query.roomCount)),
      row('иғҪеҠӣиҫ№з•Ң', HOTEL_LIMITATION)
    ],
    rawPreview: ''
  };
}

function detailAction(hotel: HotelSearchItem, request: HotelSearchRequest): A2uiAction {
  const args: HotelDetailRequest = {
    hotelId: hotel.hotelId,
    checkInDate: request.checkInDate,
    checkOutDate: request.checkOutDate,
    countryCode: request.countryCode,
    currency: hotel.price.currency.length > 0 ? hotel.price.currency : request.currency,
    adultCount: request.adultCount,
    childCount: request.childCount,
    childAgeDetails: request.childAgeDetails.slice(),
    roomCount: request.roomCount
  };
  return {
    id: 'hotel.detail',
    label: 'жҹҘзңӢе®һж—¶жҲҝеһӢ',
    prompt: 'жҹҘзңӢ ' + hotel.name + ' зҡ„е®һж—¶жҲҝеһӢдёҺеҸ–ж¶Ҳж”ҝзӯ–',
    kind: 'prompt',
    variant: 'primary',
    args: args
  };
}

function restoreSearchAction(): A2uiAction {
  return {
    id: 'hotel.search.restore',
    label: 'иҝ”еӣһй…’еә—з»“жһң',
    prompt: 'иҝ”еӣһй…’еә—жҗңзҙўз»“жһң',
    kind: 'client',
    variant: 'secondary'
  };
}

function searchRows(hotel: HotelSearchItem, request: HotelSearchRequest): A2uiLabelValueData[] {
  const rows: A2uiLabelValueData[] = [
    row('й…’еә— ID', hotel.hotelId.toString()),
    row('Destination ID', hotel.destinationId),
    row('е…ҘдҪҸ', request.checkInDate + ' вҶ’ ' + request.checkOutDate),
    row('е®ўдәә', occupancyText(request.adultCount, request.childCount, request.roomCount)),
    row('ең°еқҖ', hotel.address),
    row('жҳҹзә§', hotel.starRating > 0 ? hotel.starRating.toString() : 'дҫӣеә”е•ҶжңӘиҝ”еӣһ'),
    row('еҸӮиҖғд»·', hotel.price.hasPrice ? numberText(hotel.price.lowestPrice) + ' ' + hotel.price.currency : 'дҫӣеә”е•ҶжңӘиҝ”еӣһ'),
    row('еҸӮиҖғд»·еҸЈеҫ„', HOTEL_SEARCH_PRICE_SCOPE),
    row('д»·ж јиҜҙжҳҺ', hotel.price.message),
    row('и®ҫж–Ҫ', hotel.hotelAmenities.join(' В· ')),
    row('ж Үзӯҫ', hotel.tags.join(' В· ')),
    row('иғҪеҠӣиҫ№з•Ң', HOTEL_LIMITATION)
  ];
  if (hotel.bookingUrl.length > 0) {
    rows.push(row('з¬¬дёүж–№йў„и®ўпјҲзҰ»ејҖ Applessпјү', hotel.bookingUrl));
  }
  if (hotel.imageUrl.length > 0) {
    rows.push(row('й…’еә—еӣҫзүҮ', hotel.imageUrl));
  }
  return rows;
}

function searchResultFor(hotel: HotelSearchItem, request: HotelSearchRequest): DynamicGenericToolResult {
  const price = hotel.price.hasPrice ? numberText(hotel.price.lowestPrice) + ' ' + hotel.price.currency : 'жҡӮж— д»·ж ј';
  const summaryParts: string[] = [price];
  if (hotel.address.length > 0) {
    summaryParts.push(hotel.address);
  }
  return {
    sourceTag: HOTEL_SOURCE,
    toolName: 'hotel.search',
    title: hotel.name.length > 0 ? hotel.name : hotel.nameEn,
    status: 'success',
    summary: summaryParts.join(' В· '),
    rows: searchRows(hotel, request),
    rawPreview: '',
    actions: [detailAction(hotel, request)]
  };
}

function rateRows(result: HotelDetailResult, rate: HotelRatePlan): A2uiLabelValueData[] {
  const rows: A2uiLabelValueData[] = [
    row('й…’еә— ID', result.hotelId.toString()),
    row('Rate plan ID', rate.ratePlanId),
    row('е…ҘдҪҸ', result.checkIn + ' вҶ’ ' + result.checkOut),
    row('е®ўдәә', occupancyText(result.query.adultCount, result.query.childCount, result.query.roomCount)),
    row('е№іеқҮд»·', ratePriceText(rate)),
    row('еәҠеһӢ', rate.bedTypeDescription),
    row('йӨҗйЈҹ', rate.mealTypeStr),
    row('дҫӣеә”е•ҶзЎ®и®Ө', rateAvailabilityText(rate)),
    row('еҸ–ж¶Ҳж”ҝзӯ–', rate.cancelPolicy),
    row('зЁҺиҙ№дёҺжңүж•Ҳжңҹ', HOTEL_PRICE_LIMITATION),
    row('иғҪеҠӣиҫ№з•Ң', HOTEL_LIMITATION)
  ];
  if (result.bookingUrl.length > 0) {
    rows.push(row('з¬¬дёүж–№йў„и®ўпјҲзҰ»ејҖ Applessпјү', result.bookingUrl));
  }
  return rows;
}

function rateResultFor(result: HotelDetailResult, rate: HotelRatePlan): DynamicGenericToolResult {
  const roomName = rate.roomNameCn.length > 0 ? rate.roomNameCn :
    (rate.roomName.length > 0 ? rate.roomName : rate.ratePlanName);
  const summaryParts: string[] = [ratePriceText(rate)];
  if (rate.mealTypeStr.length > 0) {
    summaryParts.push(rate.mealTypeStr);
  }
  return {
    sourceTag: HOTEL_SOURCE,
    toolName: 'hotel.detail',
    title: roomName,
    status: 'success',
    summary: summaryParts.join(' В· '),
    rows: rateRows(result, rate),
    rawPreview: ''
  };
}

export function hotelSearchA2ui(surfaceId: string, result: HotelSearchResult): string {
  const items: DynamicGenericToolResult[] = [];
  if (!result.ok) {
    items.push(searchErrorResult(result));
  } else {
    result.hotels.forEach((hotel: HotelSearchItem) => items.push(searchResultFor(hotel, result.query)));
    if (items.length === 0) {
      items.push({
        sourceTag: HOTEL_SOURCE,
        toolName: 'hotel.search',
        title: 'жІЎжңүжүҫеҲ°з¬ҰеҗҲжқЎд»¶зҡ„й…’еә—',
        status: 'empty',
        summary: result.message,
        rows: [
          row('зӣ®зҡ„ең°', result.query.place),
          row('е…ҘдҪҸ', result.query.checkInDate + ' вҶ’ ' + result.query.checkOutDate),
          row('е®ўдәә', occupancyText(result.query.adultCount, result.query.childCount, result.query.roomCount)),
          row('иғҪеҠӣиҫ№з•Ң', HOTEL_LIMITATION)
        ],
        rawPreview: ''
      });
    }
  }
  return genericToolResultsA2ui(surfaceId, 'hotel.search', items, 'hotel', 'й…’еә—жҗңзҙў');
}

export function hotelDetailA2ui(surfaceId: string, result: HotelDetailResult): string {
  const items: DynamicGenericToolResult[] = [];
  if (!result.ok) {
    items.push(detailErrorResult(result));
  } else {
    result.rates.forEach((rate: HotelRatePlan) => items.push(rateResultFor(result, rate)));
    if (items.length === 0) {
      items.push({
        sourceTag: HOTEL_SOURCE,
        toolName: 'hotel.detail',
        title: result.name,
        status: 'empty',
        summary: 'дҫӣеә”е•ҶжІЎжңүиҝ”еӣһеҸҜеұ•зӨәзҡ„е®һж—¶жҲҝеһӢгҖӮ',
        rows: [
          row('й…’еә— ID', result.hotelId.toString()),
          row('е…ҘдҪҸ', result.checkIn + ' вҶ’ ' + result.checkOut),
          row('е®ўдәә', occupancyText(result.query.adultCount, result.query.childCount, result.query.roomCount)),
          row('иғҪеҠӣиҫ№з•Ң', HOTEL_LIMITATION)
        ],
        rawPreview: ''
      });
    }
  }
  if (items.length > 0) {
    items[0].actions = [restoreSearchAction()];
  }
  return genericToolResultsA2ui(surfaceId, 'hotel.detail', items, 'hotel', result.name.length > 0 ? result.name : 'е®һж—¶жҲҝеһӢдёҺжҠҘд»·');
}

export function hotelFailureA2ui(surfaceId: string, toolId: string, message: string): string {
  const result: DynamicGenericToolResult = {
    sourceTag: HOTEL_SOURCE,
    toolName: toolId,
    title: 'й…’еә—дҫӣеә”е•Ҷи°ғз”ЁеӨұиҙҘ',
    status: 'error',
    summary: message,
    rows: [row('иғҪеҠӣиҫ№з•Ң', HOTEL_LIMITATION)],
    rawPreview: ''
  };
  return genericToolResultsA2ui(surfaceId, toolId, [result], 'hotel', 'й…’еә—жҹҘиҜў');
}
