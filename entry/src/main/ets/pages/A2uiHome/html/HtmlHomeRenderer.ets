  box-shadow: none;
}
.action.payment-icon-action {
  min-width: 0;
  min-height: 0;
  height: auto;
  padding: 6px;
  border-radius: 12px;
  border: 1px solid rgba(33, 27, 23, 0.06);
  background: #fffdfa;
  box-shadow: 0 4px 12px rgba(33, 27, 23, 0.03);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0;
  overflow: hidden;
}
.payment-action-icon {
  width: 100%;
  height: 100%;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: transparent;
}
.payment-action-icon-image {
