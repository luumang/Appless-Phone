              "properties": {
                "query": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    {
      "toolIds": ["weather.query", "maps.weather"],
      "manifest": {
        "id": "modelscope.@amap.amap-maps",
        "displayName": "高德地图",
        "sourceUrl": "https://modelscope.cn/mcp/servers/%40amap/amap-maps",
        "hosted": true,
        "fromSiteUrl": "https://lbs.amap.com/api/mcp-server/gettingstarted",
        "capabilities": ["location-services", "weather.query", "route.plan"],
        "requiredCredentials": [
          {
            "name": "AMAP_MAPS_API_KEY",
            "description": "您在高德官网上申请的key",
            "required": true,
            "placement": "env",
            "scheme": "",
            "testValue": "1"
          }
        ],
        "transports": [
          {
            "type": "stdio",
            "url": "",
            "command": "npx",
            "args": ["-y", "@amap/amap-maps-mcp-server"],
            "headers": {},
            "env": { "AMAP_MAPS_API_KEY": "" }
          }
        ],
        "tools": [
          {
            "name": "maps_weather",
            "description": "根据城市名称或 adcode 查询天气",
            "inputSchema": {
              "type": "object",
              "required": ["city"],
              "properties": {
                "city": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    {
      "toolIds": ["statistics.search"],
      "manifest": {
        "id": "modelscope.thatcoder.cnbs",
