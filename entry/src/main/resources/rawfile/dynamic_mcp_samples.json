        "sourceUrl": "https://modelscope.cn/mcp/servers/thatcoder/cnbs",
        "hosted": true,
        "fromSiteUrl": "https://github.com/icen-ai/mcp-cnbs",
        "capabilities": ["research-and-data"],
        "requiredCredentials": [
          {
            "name": "Authorization",
            "description": "Bearer token required by the hosted MCP endpoint",
            "required": false,
            "placement": "header",
            "scheme": "Bearer",
            "testValue": "1"
          }
        ],
        "transports": [
          {
            "type": "streamable_http",
            "url": "https://cnbs.mcp.icen.ai",
            "command": "",
            "args": [],
            "headers": {},
            "env": {}
          }
        ],
        "tools": [
          {
            "name": "cnbs_search",
            "description": "Search statistics",
            "inputSchema": {
              "type": "object",
              "required": ["query"],
              "properties": {
                "query": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    {
      "toolIds": ["ppt.generate"],
