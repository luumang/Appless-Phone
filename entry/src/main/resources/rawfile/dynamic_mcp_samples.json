{
  "manifests": [
    {
      "toolIds": ["fixture.echo"],
      "manifest": {
        "id": "modelscope.fixture.echo",
        "displayName": "Fixture Echo MCP",
        "sourceUrl": "local-fixture",
        "hosted": true,
        "fromSiteUrl": "",
        "capabilities": ["test.echo"],
        "requiredCredentials": [],
        "transports": [
          {
            "type": "streamable_http",
            "url": "https://fixture.invalid/mcp",
            "command": "",
            "args": [],
            "headers": {},
            "env": {}
          }
        ],
        "tools": [
          {
            "name": "echo",
            "description": "Return a deterministic echo result.",
            "inputSchema": {
              "type": "object",
