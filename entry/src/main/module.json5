{
  "module": {
    "name": "entry",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "EntryAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET"
      },
      {
        "name": "ohos.permission.APPROXIMATELY_LOCATION",
        "reason": "$string:location_permission_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.LOCATION",
        "reason": "$string:location_permission_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.MICROPHONE",
        "reason": "$string:microphone_permission_reason",
        "usedScene": {
          "abilities": [
            "EntryAbility"
          ],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.GET_BUNDLE_INFO"
      }
    ],
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "EntryAbility",
        "srcEntry": "./ets/entryability/EntryAbility.ets",
        "description": "$string:EntryAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:EntryAbility_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          },
          {
            "entities": [
              "entity.system.browsable"
            ],
            "actions": [
              "ohos.want.action.viewData"
            ],
            "uris": [
              {
                "scheme": "com.example.aiphonedemo"
              },
              {
                "scheme": "com.example.aiphonedemo",
                "pathStartWith": "oauth/google"
              },
              {
                "scheme": "com.example.aiphonedemo",
                "host": "oauth",
                "pathStartWith": "google"
              },
              {
                "scheme": "aiphone",
                "host": "oauth",
                "pathStartWith": "google"
              },
              {
                "scheme": "com.googleusercontent.apps.358078200829-covuu6l8dgvs7kaejua7mrkke7e8833b"
              },
              {
                "scheme": "com.googleusercontent.apps.358078200829-covuu6l8dgvs7kaejua7mrkke7e8833b",
                "pathStartWith": "oauth2redirect"
              }
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "NavigationCardFormExtensionAbility",
        "srcEntry": "./ets/extensionability/NavigationCardFormExtensionAbility.ets",
        "type": "form",
        "description": "$string:NavigationCardFormExtensionAbility_desc",
        "icon": "$media:layered_image",
        "label": "$string:NavigationCardFormExtensionAbility_label",
        "exported": true,
        "metadata": [
          {
            "name": "ohos.extension.form",
            "resource": "$profile:navigation_card_form_config"
          }
        ]
      },
      {
        "name": "EntryBackupAbility",
        "srcEntry": "./ets/entrybackupability/EntryBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ],
      }
    ]
  }
}
